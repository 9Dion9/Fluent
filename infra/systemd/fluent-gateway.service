[Unit]
Description=Fluent inference gateway (FastAPI over Ollama + Piper + ffmpeg)
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=dion
WorkingDirectory=/srv/bots/Fluent/gateway
EnvironmentFile=/srv/bots/Fluent/gateway/.env
ExecStart=/srv/bots/Fluent/gateway/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
