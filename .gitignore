# secrets — never commit
.dev.vars
*.env
secrets/

# node
node_modules/
npm-debug.log*

# wrangler
.wrangler/
worker/.wrangler/
infra/.wrangler/

# python
__pycache__/
*.pyc
.venv/
venv/

# xcode / ios
app/build/
app/DerivedData/
*.xcuserstate
xcuserdata/
.DS_Store

# generated audio (reproducible from the batch pipeline)
**/*.m4a
**/*.wav

# gateway: downloaded binaries/models — fetched by gateway/scripts/setup_piper.sh
gateway/bin/
gateway/voices/

# batch: generated SQL/JSONL output + cached frequency lists (reproducible from source data)
batch/output/
batch/.cache/

# editor
.vscode/
.idea/
infra/.cf_token

# nightly D1 export backups (real user data — never commit)
infra/backups/
infra/.health_state/
